generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         Int       @id @default(autoincrement())
  telegramId BigInt    @unique // Зберігаємо ID з Telegram (BigInt, бо ID бувають дуже довгими)
  createdAt  DateTime  @default(now())
  workouts   Workout[] // Зв'язок 1 до багатьох: один користувач має багато тренувань
}

model Workout {
  id        Int        @id @default(autoincrement())
  user      User       @relation(fields: [userId], references: [id])
  userId    Int
  status    String     @default("ACTIVE") // Може бути "ACTIVE" або "FINISHED"
  startTime DateTime   @default(now())
  endTime   DateTime?  // Може бути порожнім, поки тренування не завершено
  exercises Exercise[] // Зв'язок: в одному тренуванні багато вправ
}

model Exercise {
  id         Int      @id @default(autoincrement())
  workout    Workout  @relation(fields: [workoutId], references: [id])
  workoutId  Int
  rawText    String   // Оригінальне повідомлення (напр. "Присід 3 по 10")
  name       String?  // Розпарсена назва ("Присідання")
  sets       Int?     // Кількість підходів (3)
  reps       Int?     // Кількість повторень (10)
  createdAt  DateTime @default(now())
}