<?xml version="1.0" encoding="utf-8"?>
<Project>
  <PropertyGroup>
    <PackageJsonName Condition="$(PackageJsonName) == ''">workoutdiarybot</PackageJsonName>
    <PackageJsonVersion Condition="$(PackageJsonVersion) == ''">1.0.0</PackageJsonVersion>
    <PackageJsonMain Condition="$(PackageJsonMain) == ''">app.js</PackageJsonMain>
    <PackageJsonScriptsTest Condition="$(PackageJsonScriptsTest) == ''">echo "Error: no test specified" &amp;&amp; exit 1</PackageJsonScriptsTest>
    <PackageJsonKeywords Condition="$(PackageJsonKeywords) == ''">[]</PackageJsonKeywords>
    <PackageJsonAuthor Condition="$(PackageJsonAuthor) == ''"></PackageJsonAuthor>
    <PackageJsonLicense Condition="$(PackageJsonLicense) == ''">ISC</PackageJsonLicense>
    <PackageJsonDescription Condition="$(PackageJsonDescription) == ''"></PackageJsonDescription>
    <PackageJsonDevdependenciesEslint Condition="$(PackageJsonDevdependenciesEslint) == ''">^9.39.4</PackageJsonDevdependenciesEslint>
    <PackageJsonDevdependenciesPrisma Condition="$(PackageJsonDevdependenciesPrisma) == ''">^6.19.2</PackageJsonDevdependenciesPrisma>
    <PackageJsonDependenciesPrismaClient Condition="$(PackageJsonDependenciesPrismaClient) == ''">^6.19.2</PackageJsonDependenciesPrismaClient>
    <PackageJsonDependenciesAxios Condition="$(PackageJsonDependenciesAxios) == ''">^1.13.6</PackageJsonDependenciesAxios>
    <PackageJsonDependenciesDotenv Condition="$(PackageJsonDependenciesDotenv) == ''">^17.3.1</PackageJsonDependenciesDotenv>
    <PackageJsonDependenciesOpenai Condition="$(PackageJsonDependenciesOpenai) == ''">^6.32.0</PackageJsonDependenciesOpenai>
    <PackageJsonDependenciesTelegraf Condition="$(PackageJsonDependenciesTelegraf) == ''">^4.16.3</PackageJsonDependenciesTelegraf>
  </PropertyGroup>
</Project>